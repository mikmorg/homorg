    "@testing-library/svelte": "^5.3.1",
    "@types/qrcode": "^1.5.6",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.7.3",
    "vite": "^6.2.1",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.0",
    "workbox-window": "^7.3.0"
  },
