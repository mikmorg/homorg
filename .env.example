# Homorg - Personal Inventory System
DATABASE_URL=postgres://homorg:homorg_dev@localhost:5432/homorg
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_64_char_random_string
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_DAYS=30
LISTEN_ADDR=0.0.0.0:8080
BARCODE_PREFIX=HOM
BARCODE_PAD_WIDTH=6
STORAGE_PATH=./data/images
MAX_BATCH_SIZE=500
CORS_ORIGINS=*
RUST_LOG=homorg=debug,tower_http=debug

# Database pool tuning
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_ACQUIRE_TIMEOUT_SECS=30
DB_IDLE_TIMEOUT_SECS=600
DB_MAX_LIFETIME_SECS=1800

# Upload limits
MAX_UPLOAD_BYTES=10485760
ALLOWED_IMAGE_MIMES=image/jpeg,image/png,image/webp,image/gif

# Rate limiting disabled for development — set RATE_LIMIT_RPS to enable for production
# Dev environment: leave disabled (RATE_LIMIT_RPS not set)
# Production: set to appropriate values (e.g. RATE_LIMIT_RPS=50, RATE_LIMIT_BURST=200)
# RATE_LIMIT_RPS=10
# RATE_LIMIT_BURST=30

# Logging format: "text" or "json"
LOG_FORMAT=text
